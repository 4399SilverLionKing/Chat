{
  "name": "chat-tools-ts",
  "private": true,
  "packageManager": "pnpm@10.26.2",
  "scripts": {
    "build": "pnpm -r build",
    "dev": "node scripts/dev-runner.mjs",
    "dev:web": "pnpm --filter @chat-tools/web dev",
    "dev:web-server": "pnpm --filter @chat-tools/web dev:server",
    "analyze": "pnpm --filter @chat-tools/cli dev -- analyze-chat-profile",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "typecheck": "pnpm -r typecheck"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "concurrently": "^9.2.1",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
