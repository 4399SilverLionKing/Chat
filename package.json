{
  "name": "chat-tools-ts",
  "private": true,
  "packageManager": "pnpm@10.26.2",
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm --filter @chat-tools/cli dev",
    "analyze": "pnpm --filter @chat-tools/cli dev -- analyze-chat-profile",
    "reply": "pnpm --filter @chat-tools/cli dev -- generate-reply-strategy",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "typecheck": "pnpm -r typecheck"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
